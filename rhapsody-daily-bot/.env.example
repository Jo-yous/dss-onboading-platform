# X (Twitter) API – from Developer Portal → Your App → Keys and Tokens
# Required: OAuth 1.0a User Context (Read + Write, Automated App / Bot)
X_API_KEY=your_api_key
X_API_SECRET=your_api_key_secret
X_ACCESS_TOKEN=your_access_token
X_ACCESS_SECRET=your_access_token_secret

# Optional: custom daily excerpt (leave unset for generic teaser)
# TODAY_TITLE=Today's devotional title
# TODAY_VERSE=Key verse or short excerpt text
# TODAY_TEXT=Same as TODAY_VERSE (alternative name)
